name: Flask CI Pipeline

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: 🧾 Cloner le dépôt
        uses: actions/checkout@v4

      - name: 🐍 Configurer Python 3.10
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: 📦 Installer les dépendances
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: ✅ Exécuter les tests unitaires
        run: pytest tests/ --verbose

      - name: 🛡️ Audit de sécurité des dépendances
        run: |
          pip install pip-audit
          pip-audit

  notify:
    needs: build
    if: failure()
    runs-on: ubuntu-latest
    steps:
      - name: 🚨 Envoyer alerte email
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ secrets.MAIL_USER }}
          password: ${{ secrets.MAIL_PASS }}
          to: leonelpengou10@gmail.com
          subject: "🚨 Échec CI - DevOps FlaskApp"
          body: |
            ❌ Échec du pipeline CI !
            👉 Repo    : ${{ github.repository }}
            👉 Branche : ${{ github.ref }}
            👉 Commit  : ${{ github.sha }}
            👉 Logs    : ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}

  release:
    if: startsWith(github.ref, 'refs/tags/v')
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: 🧾 Cloner le dépôt
        uses: actions/checkout@v4

      - name: 📦 Créer une Release GitHub
        uses: softprops/action-gh-release@v1
        with:
          tag_name: ${{ github.ref_name }}
          name: Release ${{ github.ref_name }}
          body: |
            ## Release ${{ github.ref_name }} - DevOps FlaskApp
            - ✅ Tests unitaires validés (pytest)
            - 🛡️ Audit de sécurité effectué (pip-audit)
            - 🚀 Déployé automatiquement via GitHub Actions
          draft: false
          prerelease: false
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
